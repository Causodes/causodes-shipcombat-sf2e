{{!-- Gunner tab (5-player: same as 6 but with Deployed Torpedoes) --}}
<section class="tab {{tab.cssClass}}" data-group="primary" data-tab="{{tab.id}}">

    {{> "gunner-claim-prompt"}}
    {{> "gunner-captain-boost"}}
    {{> "gunner-status-bar"}}
    {{> "gunner-ordnance-allocation"}}

    {{#if (or isGM (lookup (lookup roles "gunner") "isMyRole"))}}
    <nav class="sub-nav">
        <a data-sub-tab="weapons">{{localize "SHIPCOMBAT.SubTab.Weapons"}}</a>
        <a data-sub-tab="overcharge">{{localize "SHIPCOMBAT.SubTab.Overcharge"}}</a>
    </nav>
    <div class="role-panels">
        <div class="tab" data-sub-tab="weapons">
            {{> "deployed-torpedoes"}}
            {{> "gunner-weapon-batteries"}}
        </div>
        <div class="tab" data-sub-tab="overcharge">
            {{> "gunner-core-actions"}}
        </div>
    </div>
    {{/if}}

    {{> 'complete-turn' tabRoleId="gunner" turnDone=(lookup @root.sys.turnDone "gunner")}}

</section>
