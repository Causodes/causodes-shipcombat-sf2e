{{!-- Engineer tab (5-player: includes Voidshields) with subtab navigation --}}
<section class="tab {{tab.cssClass}}" data-group="primary" data-tab="{{tab.id}}">

    {{> "engineer-claim-prompt"}}
    {{> "engineer-captain-boost"}}
    {{> "engineer-status-bar"}}

    {{#if (or isGM (lookup (lookup roles "engineer") "isMyRole"))}}
    <nav class="sub-nav">
        <a data-sub-tab="shields">{{localize "SHIPCOMBAT.SubTab.Shields"}}</a>
        <a data-sub-tab="core">{{localize "SHIPCOMBAT.SubTab.Core"}}</a>
    </nav>
    <div class="role-panels">
        <div class="tab" data-sub-tab="shields">
            {{> "captain-voidshields"}}
        </div>
        <div class="tab" data-sub-tab="core">
            {{> "engineer-core-distribution"}}
            {{> "engineer-heat-management"}}
            {{> "engineer-fire-suppression"}}
            {{> "engineer-hull-repair"}}
        </div>
    </div>
    {{/if}}

    {{> 'complete-turn' tabRoleId="engineer" turnDone=(lookup @root.sys.turnDone "engineer")}}

</section>
