{{!-- Captain tab (4-player: merged Captain+Sensors/Augur) with subtab navigation --}}
<section class="tab {{tab.cssClass}}" data-group="primary" data-tab="{{tab.id}}">

    {{> "captain-claim-prompt"}}
    {{> "captain-status-bar"}}
    {{> "captain-leadership"}}

    {{#if (or isGM (lookup (lookup roles "captain") "isMyRole"))}}
    {{> "captain-conditions"}}
    {{> "sensors-bda"}}
    <nav class="sub-nav">
        <a data-sub-tab="orders">{{localize "SHIPCOMBAT.SubTab.Orders"}}</a>
        <a data-sub-tab="radar">{{localize "SHIPCOMBAT.SubTab.Radar"}}</a>
        <a data-sub-tab="abilities">{{localize "SHIPCOMBAT.SubTab.Abilities"}}</a>
    </nav>
    <div class="role-panels">
        <div class="tab" data-sub-tab="orders">
            {{> "captain-hand"}}
            {{> "captain-active-orders"}}
        </div>
        <div class="tab" data-sub-tab="radar">
            {{> "sensors-radar"}}
        </div>
        <div class="tab" data-sub-tab="abilities">
            {{> "sensors-abilities-ref"}}
        </div>
    </div>

    {{/if}}

    {{> 'complete-turn' tabRoleId="captain" turnDone=(lookup @root.sys.turnDone "captain")}}

</section>
