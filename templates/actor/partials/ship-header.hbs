<header class="char-header">
  <div class="char-details">
    <h1 class="char-name">
      <input type="text" name="name" value="{{actor.name}}"
             placeholder="{{localize 'SHIPCOMBAT.NpcShip.ShipName'}}"
             {{#unless isGM}}disabled{{/unless}}>
    </h1>
    {{#if actorRarities}}
    <div class="tags">
      <select class="rarity rarity-select {{sys.traits.rarity}}" name="system.traits.rarity"
              {{#unless isGM}}disabled{{/unless}}>
        {{selectOptions actorRarities selected=sys.traits.rarity localize=true}}
      </select>
      {{#if actorSizes}}
      <select class="size size-select" name="system.traits.size.value"
              {{#unless isGM}}disabled{{/unless}}>
        {{selectOptions actorSizes selected=sys.traits.size.value localize=true}}
      </select>
      {{/if}}
    </div>
    {{/if}}
  </div>
  <div class="char-level">
    <div class="level">
      <label>{{localize "SHIPCOMBAT.Label.ShipLevel"}}</label>
      <input name="system.details.level.value" type="number"
             value="{{sys.details.level.value}}" placeholder="1" size="2" />
    </div>
  </div>
</header>
