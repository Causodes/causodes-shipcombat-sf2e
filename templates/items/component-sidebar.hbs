{{!-- Component Summary sidebar — mirrors physical-sidebar.hbs (weapon layout) --}}
<div class="inventory-details">

    <div class="form-group quantity">
        <label for="comp-quantity">{{localize "PF2E.QuantityLabel"}}</label>
        <input type="number" name="system.quantity" id="comp-quantity"
               value="{{sys.quantity}}" min="0" />
    </div>

    {{!-- Slot replaces Hands --}}
    <div class="form-group">
        <label for="comp-slot">{{localize "SHIPCOMBAT.Label.Slot"}}</label>
        <select name="system.slot" id="comp-slot">
            {{#each slotChoices}}
                <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
            {{/each}}
        </select>
    </div>

    <div class="form-group">
        <label for="comp-bulk">{{localize "PF2E.Item.Physical.Bulk.Label"}}</label>
        <select name="system.bulk" id="comp-bulk">
            {{#each bulkChoices}}
                <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
            {{/each}}
        </select>
    </div>

    <div class="form-group">
        <label for="comp-size">{{localize "PF2E.Size"}}</label>
        <select name="system.size" id="comp-size">
            {{#each sizeChoices}}
                <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
            {{/each}}
        </select>
    </div>

    <div class="form-group price">
        <label for="comp-cost">{{localize "PF2E.PriceLabel"}}</label>
        <div class="form-fields">
            <input type="number" name="system.cost" id="comp-cost"
                   value="{{sys.cost}}" min="0" />
        </div>
    </div>

</div>
