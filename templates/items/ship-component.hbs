{{!--
  ship-component.hbs — Ship Component item sheet
  Structural copy of systems/pf2e/templates/items/sheet.hbs adapted for
  our component schema.  Differences from the original:
    • sys.rarity / sys.tier instead of item.rarity / data.level.value
    • level input name="system.tier" (not data-property)
    • rarity select name="system.rarity" (not system.traits.rarity)
    • detailsTemplate / sidebarTemplate provided by ShipComponentSheetSF2e.getData()
    • mystification and rules panels are our own simplified versions
--}}
<form class="{{cssClass}}" autocomplete="off" spellcheck="false" data-tooltip-class="pf2e">

    {{!-- ── HEADER ──────────────────────────────────────────────────────────── --}}
    <header class="sheet-header">
        <img src="{{item._source.img}}" data-edit="img" />
        <div class="details">
            <input
                name="name"
                type="text"
                value="{{item._source.name}}"
                placeholder="{{localize 'PF2E.ItemNamePlaceholder'}}"
                spellcheck="false"
                aria-label="{{localize 'PF2E.ItemNamePlaceholder'}}"
            />
            {{#if itemType}}
                <span class="level">
                    <span>{{itemType}}</span>
                    <input
                        type="number"
                        name="system.tier"
                        required="true"
                        min="0"
                        value="{{sys.tier}}"
                        aria-label="{{localize 'PF2E.LevelLabel'}}"
                    />
                </span>
            {{/if}}
            {{!-- Rarity rendered directly (AppV1: no <template> JS injection) --}}
            <div class="paizo-style tags">
                <select class="tag rarity {{sys.rarity}}" name="system.rarity">
                    {{selectOptions rarities selected=sys.rarity localize=true}}
                </select>
            </div>
        </div>
    </header>

    {{!-- ── TAB NAVIGATION ─────────────────────────────────────────────────── --}}
    <nav class="sheet-tabs">
        {{#if sidebarTemplate}}
            <div class="sidebar-summary">{{sidebarTitle}}</div>
        {{/if}}
        <div class="tabs" data-tab-container="primary">
            <a class="list-row" data-tab="description">{{localize "DOCUMENT.FIELDS.description.label"}}</a>
            <a class="list-row" data-tab="details">{{localize "PF2E.Details"}}</a>
            {{#if user.isGM}}
                <a class="list-row" data-tab="mystification">{{localize "PF2E.ItemMystification"}}</a>
            {{/if}}
            <a class="list-row" data-tab="rules">{{localize "PF2E.Item.Rules.Tab"}}</a>
        </div>
    </nav>

    {{!-- ── SHEET CONTENT ───────────────────────────────────────────────────── --}}
    <div class="sheet-content">

        {{!-- Sidebar (mirrors physical item sheet Equipment Summary panel) --}}
        {{#if sidebarTemplate}}
            <section class="sidebar" data-tooltip-direction="UP">
                {{> (lookup . "sidebarTemplate")}}
            </section>
        {{/if}}

        <div class="sheet-body">

            {{!-- Description tab --}}
            <section class="tab description" data-tab="description" data-tooltip-class="">
                {{#if user.isGM}}
                    <section class="editor-container gm-notes{{#if enrichedContent.gmNotes}} has-content{{/if}}">
                        {{editor enrichedContent.gmNotes target="system.notes.gm"
                            button=true owner=owner editable=editable engine="prosemirror"}}
                    </section>
                {{/if}}
                <section class="main editor-container">
                    {{editor enrichedContent.description target="system.notes.player"
                        button=true owner=owner editable=editable engine="prosemirror"}}
                </section>
            </section>

            {{!-- Details tab: delegates to component-details.hbs from core --}}
            <section
                class="tab details{{#unless sidebarTemplate}} no-sidebar{{/unless}}"
                data-tab="details"
                data-tooltip-direction="UP"
            >
                {{> (lookup . "detailsTemplate")}}
            </section>

            {{!-- Mystification tab (GM only, simplified) --}}
            {{#if user.isGM}}
                <section class="tab mystification" data-tab="mystification">
                    <fieldset>
                        <legend>{{localize "PF2E.identification.DisplayDetails"}}</legend>
                        <div class="form-group identification-data unidentified">
                            <div class="img-name">
                                <img
                                    class="mystify-control image-picker"
                                    src="{{item._source.img}}"
                                    data-edit="system.identification.unidentified.img"
                                />
                                <input
                                    type="text"
                                    name="system.identification.unidentified.name"
                                    value="{{item._source.name}}"
                                    class="mystify-control"
                                />
                            </div>
                            <p class="hint">{{localize "PF2E.identification.Unidentified"}}</p>
                        </div>
                    </fieldset>
                </section>
            {{/if}}

            {{!-- Rules tab: UUID / sourceId / slug --}}
            <section class="tab rules" data-tab="rules" data-tooltip-direction="UP">
                <div class="nerd-details flexcol">
                    <div class="form-group">
                        <label>{{localize "PF2E.UUID.Label"}}</label>
                        <div class="form-fields">
                            <input type="text" value="{{item.uuid}}" readonly />
                        </div>
                    </div>
                    {{#if item.sourceId}}
                        <div class="form-group">
                            <label>{{localize "PF2E.UUID.SourceId"}}</label>
                            <div class="form-fields">
                                <input type="text" value="{{item.sourceId}}" readonly />
                            </div>
                        </div>
                    {{/if}}
                    <div class="form-group">
                        <label>{{localize "PF2E.Slug"}}</label>
                        <div class="form-fields">
                            <input type="text" name="system.slug" value="{{sys.slug}}" />
                        </div>
                    </div>
                </div>
            </section>

        </div>
    </div>

</form>
